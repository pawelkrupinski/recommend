<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">
    <!-- releaseFast is the non-debug build the DevPanel installs over cable for a
         local smoke test; like the debug overlay it may point at the Mac's dev
         server over http (adb reverse tcp:9002), so re-enable cleartext for this
         local-only variant. The shipped `release` build keeps
         usesCleartextTraffic=false and talks to https://filmowo.fly.dev. -->
    <application
        android:usesCleartextTraffic="true"
        tools:replace="android:usesCleartextTraffic" />
</manifest>
