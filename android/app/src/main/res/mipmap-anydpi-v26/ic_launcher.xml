<?xml version="1.0" encoding="utf-8"?>
<!-- Adaptive icon (API 26+, our minSdk), matching the movies app: the red-TV
     artwork sits centred on its navy field in the background layer with a
     margin, so the launcher mask just rounds the corners and the TV shows
     fully at a comfortable size (not zoomed/cropped as a foreground would be).
     Foreground is empty. -->
<adaptive-icon xmlns:android="http://schemas.android.com/apk/res/android">
    <background android:drawable="@mipmap/ic_launcher_art" />
    <foreground android:drawable="@android:color/transparent" />
</adaptive-icon>
