{
  "name": "recommend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Taste-learning movie/TV recommender filtered to what's streamable in your country (Movie of the Night + Criticker, mashed up).",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "build": "node scripts/build-assets.js",
    "test": "node --test --test-force-exit \"test/unit/**/*.test.js\" \"test/integration/**/*.test.js\"",
    "test:unit": "node --test --test-force-exit \"test/unit/**/*.test.js\"",
    "test:integration": "node --test --test-force-exit \"test/integration/**/*.test.js\"",
    "test:e2e": "playwright test",
    "test:e2e:install": "playwright install --with-deps chromium",
    "harvest:tones": "node --env-file=.env.local scripts/harvest-tmdb-tones.js",
    "harvest:netflix-tones": "node --env-file=.env.local scripts/harvest-netflix-tones.js",
    "train:tone-model": "node --env-file=.env.local scripts/train-tone-model.js",
    "service:install": "bash service/recommend-service.sh install",
    "service:uninstall": "bash service/recommend-service.sh uninstall",
    "service:restart": "bash service/recommend-service.sh restart",
    "service:status": "bash service/recommend-service.sh status",
    "service:logs": "bash service/recommend-service.sh logs"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "esbuild": "^0.28.1"
  },
  "dependencies": {
    "prom-client": "^15.1.3",
    "undici": "^8.5.0"
  }
}
