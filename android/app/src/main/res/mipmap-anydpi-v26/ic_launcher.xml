<?xml version="1.0" encoding="utf-8"?>
<!-- Adaptive launcher icon (API 26+, which is our minSdk): the red-TV artwork
     over the navy field it was designed on, so any launcher mask (circle,
     squircle, rounded square) crops navy corners rather than clipping the TV. -->
<adaptive-icon xmlns:android="http://schemas.android.com/apk/res/android">
    <background android:drawable="@color/ic_launcher_background" />
    <foreground android:drawable="@mipmap/ic_launcher_foreground" />
</adaptive-icon>
